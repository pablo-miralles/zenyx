{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"name": "Protagonista",
					"slug": "protagonista",
					"color": "#083b51"
				},
				{
					"name": "Neutral Light",
					"slug": "neutral-light",
					"color": "#c1d9e4"
				},
				{
					"name": "Acento",
					"slug": "acento",
					"color": "#fe7756"
				},
				{
					"name": "White",
					"slug": "white",
					"color": "#ffffff"
				},
				{
					"name": "Neutral Dark",
					"slug": "neutral-dark",
					"color": "#cccccc"
				},
				{
					"name": "Black",
					"slug": "black",
					"color": "#18181b"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"name": "Space Grotesk",
					"slug": "body",
					"fontFamily": "\"Space Grotesk\", sans-serif"
				},
				{
					"name": "RZ Regular",
					"slug": "heading",
					"fontFamily": "\"RZ-Regular\", sans-serif"
				}
			],
			"fontSizes": [
				{
					"name": "H1",
					"slug": "h1",
					"size": "64px"
				},
				{
					"name": "H2",
					"slug": "h2",
					"size": "48px"
				},
				{
					"name": "H3",
					"slug": "h3",
					"size": "40px"
				},
				{
					"name": "H4",
					"slug": "h4",
					"size": "32px"
				},
				{
					"name": "H5",
					"slug": "h5",
					"size": "24px"
				},
				{
					"name": "H6",
					"slug": "h6",
					"size": "20px"
				},
				{
					"name": "Body",
					"slug": "body",
					"size": "16px"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--neutral-light)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "clamp(1rem, 0.95rem + 0.2vw, 1.125rem)"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"lineHeight": "1.2",
					"fontWeight": "400"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--protagonista)",
					"text": "var(--wp--preset--color--white)"
				},
				"typography": {
					"fontWeight": "500",
					"fontSize": "1rem"
				},
				"spacing": {
					"padding": {
						"top": "0.25rem",
						"bottom": "0.25rem",
						"left": "1rem",
						"right": "1rem"
					}
				}
			}
		}
	}
}