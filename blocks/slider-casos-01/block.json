{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "zenyx/slider-casos-01",
	"title": "Zenyx slider casos 01",
	"description": "Slider de casos de exito con cards reutilizables, modo relacionados o manual.",
	"category": "theme",
	"icon": "slides",
	"textdomain": "zenyx",
	"keywords": [
		"casos",
		"slider",
		"caso"
	],
	"supports": {
		"html": false,
		"align": false
	},
	"attributes": {
		"sectionTitle": {
			"type": "string",
			"default": "Otros casos de éxito que te pueden interesar"
		},
		"leadText": {
			"type": "string",
			"default": "Más de 140 agencias ya lo han conseguido."
		},
		"ctaText": {
			"type": "string",
			"default": "Ver todos los casos de éxito"
		},
		"ctaUrl": {
			"type": "string",
			"default": ""
		},
		"centerContent": {
			"type": "boolean",
			"default": false
		},
		"sourceMode": {
			"type": "string",
			"default": "manual"
		},
		"relatedLimit": {
			"type": "number",
			"default": 8
		},
		"manualPostIds": {
			"type": "array",
			"default": [],
			"items": {
				"type": "number"
			}
		}
	},
	"editorScript": "file:./build/index.js",
	"viewScript": "file:./build/view.js",
	"render": "file:./render.php"
}