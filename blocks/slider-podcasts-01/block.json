{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "zenyx/slider-podcasts-01",
	"title": "Zenyx slider podcasts 01",
	"description": "Slider de episodios de podcast con miniatura, metas y enlaces a Spotify y YouTube.",
	"category": "theme",
	"icon": "slides",
	"textdomain": "zenyx",
	"keywords": [ "podcast", "slider", "episodios" ],
	"supports": {
		"html": false,
		"align": false
	},
	"attributes": {
		"sectionTitle": {
			"type": "string",
			"default": "Episodios más escuchados"
		},
		"manualPostIds": {
			"type": "array",
			"default": [],
			"items": {
				"type": "number"
			}
		}
	},
	"editorScript": "file:./build/index.js",
	"viewScript": "file:./build/view.js",
	"render": "file:./render.php"
}
